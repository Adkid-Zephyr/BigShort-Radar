# 复制为 .env 后填入真实值。.env 不进 git。
# FRED API Key 申请：https://fred.stlouisfed.org/docs/api/api_key.html （免费）
FRED_API_KEY=

# 时区
TZ=Asia/Shanghai

# Flask
FLASK_PORT=5050
FLASK_DEBUG=0

# LLM 调用（用于风险日报与 chatbot 分析；缺省可不配，相关功能自动降级）
# 阿里百炼 Coding Plan（OpenAI 协议兼容）：
#   DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
#   DASHSCOPE_MODEL=qwen3-coder-plus  # 百炼 Coding Plan 实测可用；未列出 qwen-max 不支持
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
DASHSCOPE_MODEL=qwen-max
